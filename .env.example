# Copy this file to .env and set real values for secrets.
# PowerShell: Copy-Item .env.example .env

# Database
APP_DB_NAME=appdb
APP_DB_USER=app
APP_DB_PASSWORD=change_me

# Keycloak admin bootstrap
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change_me

# Resource server introspection credentials
KEYCLOAK_RESOURCE_CLIENT_ID=resource-server
KEYCLOAK_RESOURCE_CLIENT_SECRET=change_me

# Keycloak base URL for app container
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080

# Grafana admin
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me

# Observability
OTEL_SERVICE_NAME=jwt-demo-reactive
MANAGEMENT_OTLP_TRACING_ENDPOINT=http://otel-collector:4318/v1/traces
MANAGEMENT_OTLP_LOGGING_ENDPOINT=http://otel-collector:4318/v1/logs


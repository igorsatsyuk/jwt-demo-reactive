          "editorMode": "code",
          "expr": "topk(10, 1000 * sum by (uri) (rate(http_server_requests_seconds_sum{application=~\"$application\",uri!~\"UNKNOWN|/actuator.*\"}[5m])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{application=~\"$application\",uri!~\"UNKNOWN|/actuator.*\"}[5m])), 1))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{uri}}",
          "range": false,
          "refId": "A"
        }
      ],
